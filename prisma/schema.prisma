generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Game {
  id                String              @id
  name              String
  category          String
  DewanyahGame      DewanyahGame[]
  matches           Match[]
  rooms             Room[]
  SponsorGame       SponsorGame[]
  SponsorGameStat   SponsorGameStat[]
  SponsorGameWallet SponsorGameWallet[]
  TimelineEvent     TimelineEvent[]
  UserGameStat      UserGameStat[]
  UserGameWallet    UserGameWallet[]
}

model User {
  id                String              @id @default(uuid())
  publicId          String              @unique @default(cuid())
  email             String              @unique
  phone             String?             @unique
  phoneVerifiedAt   DateTime?
  isTestAccount     Boolean             @default(false)
  displayName       String
  passwordHash      String?
  createdAt         DateTime            @default(now())
  creditPoints      Int                 @default(5)
  creditBalance     Int                 @default(0)
  permanentScore    Int                 @default(0)
  pearls            Int                 @default(5)
  hideFromLeaderboard Boolean           @default(false)
  pearlsSeasonYm    Int?
  themeId           String?
  frameId           String?
  cardId            String?
  birthDate         DateTime?
  avatarBase64      String?
  avatarPath        String?
  DewanyahMember    DewanyahMember[]
  DewanyahRequest   DewanyahRequest[]
  matchParts        MatchParticipant[]
  roomsHosted       Room[]              @relation("RoomsHosted")
  roomPlayers       RoomPlayer[]
  roomResultVotes   RoomResultVote[]
  RoomStake         RoomStake[]
  SponsorGameStat   SponsorGameStat[]
  SponsorGameWallet SponsorGameWallet[]
  timeline          TimelineEvent[]
  UserGameStat      UserGameStat[]
  UserGameWallet    UserGameWallet[]
  UserItem          UserItem[]
  sponsors          UserSponsor[]
}

model AuthOtpChallenge {
  id         String   @id @default(cuid())
  phone      String
  purpose    String
  codeHash   String
  expiresAt  DateTime
  attempts   Int      @default(0)
  maxAttempts Int     @default(5)
  usedAt     DateTime?
  payload    Json?
  createdAt  DateTime @default(now())

  @@index([phone, purpose, createdAt])
  @@index([expiresAt])
}

model StoreItem {
  id          String     @id
  kind        StoreKind
  name        String
  price       Int
  description String?
  preview     String?
  active      Boolean    @default(true)
  owners      UserItem[]
}

model UserItem {
  userId  String
  itemId  String
  ownedAt DateTime  @default(now())
  item    StoreItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, itemId])
  @@index([userId])
}

model Room {
  code              String           @id
  gameId            String
  hostUserId        String
  sponsorCode       String?
  status            String           @default("waiting")
  createdAt         DateTime         @default(now())
  targetWinPoints   Int?
  allowZeroCredit   Boolean          @default(false)
  timerSec          Int?
  startedAt         DateTime?
  hostLat           Float?
  hostLng           Float?
  radiusMeters      Int?             @default(100)
  resultPayload     Json?
  resultStatus      RoomResultStatus @default(waiting)
  resultSubmittedBy String?
  resultUpdatedAt   DateTime?
  matches           Match[]
  game              Game             @relation(fields: [gameId], references: [id])
  host              User             @relation("RoomsHosted", fields: [hostUserId], references: [id])
  sponsor           Sponsor?         @relation("SponsorRooms", fields: [sponsorCode], references: [code])
  players           RoomPlayer[]
  resultVotes       RoomResultVote[]
  stakes            RoomStake[]
  TimelineEvent     TimelineEvent[]
}

model RoomPlayer {
  roomCode String
  userId   String
  joinedAt DateTime  @default(now())
  team     TeamSide? @default(A)
  isLeader Boolean   @default(false)
  room     Room      @relation(fields: [roomCode], references: [code], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([roomCode, userId])
}

model RoomStake {
  roomCode   String
  userId     String
  amount     Int
  reservedAt DateTime @default(now())
  room       Room     @relation(fields: [roomCode], references: [code], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([roomCode, userId])
}

model RoomResultVote {
  roomCode  String
  userId    String
  approve   Boolean
  createdAt DateTime @default(now())
  room      Room     @relation(fields: [roomCode], references: [code], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([roomCode, userId])
  @@index([userId])
}

model Sponsor {
  code              String              @id
  name              String
  active            Boolean             @default(true)
  imageUrl          String?
  themePrimary      String?
  themeAccent       String?
  matches           Match[]             @relation("SponsorMatches")
  rooms             Room[]              @relation("SponsorRooms")
  SponsorGame       SponsorGame[]
  SponsorGameStat   SponsorGameStat[]
  SponsorGameWallet SponsorGameWallet[]
  users             UserSponsor[]
}

model UserSponsor {
  userId      String
  sponsorCode String
  activatedAt DateTime @default(now())
  sponsor     Sponsor  @relation(fields: [sponsorCode], references: [code], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, sponsorCode])
}

model Match {
  id          String             @id @default(uuid())
  roomCode    String?
  gameId      String
  createdAt   DateTime           @default(now())
  sponsorCode String?
  game        Game               @relation(fields: [gameId], references: [id])
  room        Room?              @relation(fields: [roomCode], references: [code])
  sponsor     Sponsor?           @relation("SponsorMatches", fields: [sponsorCode], references: [code])
  parts       MatchParticipant[]
}

model MatchParticipant {
  matchId String
  userId  String
  outcome Outcome
  match   Match   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([matchId, userId])
}

model TimelineEvent {
  id        String   @id @default(uuid())
  userId    String?
  roomCode  String?
  gameId    String?
  kind      String
  meta      Json?
  createdAt DateTime @default(now())
  game      Game?    @relation(fields: [gameId], references: [id])
  room      Room?    @relation(fields: [roomCode], references: [code])
  user      User?    @relation(fields: [userId], references: [id])
}

model SponsorGame {
  sponsorCode String
  gameId      String
  prizeAmount Int     @default(0)
  game        Game    @relation(fields: [gameId], references: [id], onDelete: Cascade)
  sponsor     Sponsor @relation(fields: [sponsorCode], references: [code], onDelete: Cascade)

  @@id([sponsorCode, gameId])
}

model SponsorGameWallet {
  userId      String
  sponsorCode String
  gameId      String
  pearls      Int      @default(5)
  seasonYm    Int?
  updatedAt   DateTime @updatedAt
  game        Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  sponsor     Sponsor  @relation(fields: [sponsorCode], references: [code], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, sponsorCode, gameId])
  @@index([sponsorCode, gameId])
  @@index([userId])
}

model UserGameWallet {
  userId    String
  gameId    String
  pearls    Int      @default(5)
  seasonYm  Int?
  updatedAt DateTime @updatedAt
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, gameId])
  @@index([gameId])
  @@index([userId])
}

model UserGameStat {
  userId    String
  gameId    String
  wins      Int      @default(0)
  losses    Int      @default(0)
  streak    Int      @default(0)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, gameId])
  @@index([gameId])
}

model SponsorGameStat {
  sponsorCode String
  gameId      String
  userId      String
  wins        Int      @default(0)
  losses      Int      @default(0)
  streak      Int      @default(0)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
  game        Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  sponsor     Sponsor  @relation(fields: [sponsorCode], references: [code], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sponsorCode, gameId, userId])
  @@index([sponsorCode, gameId])
  @@index([userId])
}

model Dewanyah {
  id              String           @id @default(uuid())
  name            String
  ownerUserId     String
  ownerEmail      String?
  ownerName       String?
  imageUrl        String?
  themePrimary    String?
  themeAccent     String?
  note            String?
  locationLock    Boolean          @default(false)
  radiusMeters    Int?
  requireApproval Boolean          @default(true)
  status          String           @default("active")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  games           DewanyahGame[]
  members         DewanyahMember[]
}

model DewanyahGame {
  id         String   @id @default(uuid())
  dewanyahId String
  gameId     String
  createdAt  DateTime @default(now())
  dewanyah   Dewanyah @relation(fields: [dewanyahId], references: [id], onDelete: Cascade)
  game       Game     @relation(fields: [gameId], references: [id])

  @@unique([dewanyahId, gameId])
  @@index([dewanyahId, gameId])
}

model DewanyahMember {
  id         String    @id @default(uuid())
  dewanyahId String
  userId     String
  status     String    @default("pending")
  createdAt  DateTime  @default(now())
  approvedAt DateTime?
  dewanyah   Dewanyah  @relation(fields: [dewanyahId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([dewanyahId, userId])
  @@index([userId])
}

model DewanyahRequest {
  id              String    @id @default(uuid())
  userId          String
  name            String
  contact         String
  gameId          String?
  note            String?
  requireApproval Boolean   @default(true)
  locationLock    Boolean   @default(false)
  radiusMeters    Int?
  status          String    @default("pending")
  createdAt       DateTime  @default(now())
  reviewedAt      DateTime?
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([userId])
}

enum StoreKind {
  theme
  frame
  card
}

enum TeamSide {
  A
  B
}

enum RoomResultStatus {
  waiting
  pending
  approved
  rejected
}

enum Outcome {
  WIN
  LOSS
}
